# ============================================================================
# API Gateway Environment Configuration - EXAMPLE
# ============================================================================
# Copy this file to .env and fill in your actual values
# Command: cp .env.example .env
# ============================================================================

# ────────────────────────────────────────────────────────────────────────────
# AWS CREDENTIALS
# ────────────────────────────────────────────────────────────────────────────
# Get these from: AWS Console → IAM → Users → [Your User] → Security Credentials
# See: SETUP_SECRETS_GUIDE.md for detailed instructions
AWS_ACCESS_KEY_ID=AKIA________________
AWS_SECRET_ACCESS_KEY=________________________________________
AWS_DEFAULT_REGION=us-east-1
AWS_REGION=us-east-1

# ────────────────────────────────────────────────────────────────────────────
# S3 CONFIGURATION
# ────────────────────────────────────────────────────────────────────────────
# Your S3 bucket for media uploads
S3_MEDIA_BUCKET=zerotrust-media-dev

# ────────────────────────────────────────────────────────────────────────────
# AWS BEDROCK MODELS
# ────────────────────────────────────────────────────────────────────────────
# Using billing-friendly models (Nova & Mistral) to avoid Anthropic marketplace blocks
# Enable these models in: AWS Console → Bedrock → Model Access
MANAGER_MODEL_ID=us.amazon.nova-pro-v1:0
RESEARCH_MODEL_ID=us.mistral.pixtral-large-2502-v1:0
SENTIMENT_MODEL_ID=us.amazon.nova-lite-v1:0
BEDROCK_REGION=us-east-1

# ────────────────────────────────────────────────────────────────────────────
# CLOUDWATCH LOGS (Optional)
# ────────────────────────────────────────────────────────────────────────────
CW_LOG_GROUP=/zerotrust/api-gateway
CW_LOG_STREAM_PREFIX=api-gateway

# ────────────────────────────────────────────────────────────────────────────
# SECURITY - JWT SECRET
# ────────────────────────────────────────────────────────────────────────────
# Generate a secure random secret:
# Linux/Mac: openssl rand -hex 64
# PowerShell: [Convert]::ToBase64String((1..64 | ForEach-Object { Get-Random -Min 0 -Max 255 }))
JWT_SECRET=<generate-a-secure-random-64-character-hex-string>

# ────────────────────────────────────────────────────────────────────────────
# DATABASE CONNECTION
# ────────────────────────────────────────────────────────────────────────────
# Format: postgresql://username:password@host:port/database
# For Supabase: Get from Project Settings → Database → Connection String (pooler)
DATABASE_URL=postgresql://username:password@host:5432/database

# ────────────────────────────────────────────────────────────────────────────
# MICROSERVICES URLS
# ────────────────────────────────────────────────────────────────────────────
# Media Analysis service URL (usually localhost:8001 in development)
MEDIA_ANALYSIS_URL=http://localhost:8001

# ────────────────────────────────────────────────────────────────────────────
# VERIFICATION ENGINE CONFIGURATION
# ────────────────────────────────────────────────────────────────────────────
# Timeouts increased for DuckDuckGo + Bedrock latency
MAX_AGENT_TIMEOUT=30
MAX_SOURCES_PER_AGENT=20

# ────────────────────────────────────────────────────────────────────────────
# OPTIONAL THIRD-PARTY API KEYS
# ────────────────────────────────────────────────────────────────────────────
# These are optional - the system works with free scraping by default
# See SETUP_SECRETS_GUIDE.md for where to get these keys

# News APIs (100 requests/day free tier)
# NEWS_API_KEY=your_newsapi_key
# GNEWS_API_KEY=your_gnews_key

# Google Services
# GOOGLE_SEARCH_KEY=your_google_api_key
# GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id
# GOOGLE_FACTCHECK_API_KEY=your_factcheck_api_key

# Social Media
# TWITTER_BEARER_TOKEN=your_twitter_token
# REDDIT_CLIENT_ID=your_reddit_client_id
# REDDIT_CLIENT_SECRET=your_reddit_secret

# Scientific
# PUBMED_API_KEY=your_pubmed_key

# ============================================================================
# NOTES
# ============================================================================
# 1. This file should be copied to .env and gitignored
# 2. Never commit .env with real credentials to GitHub
# 3. See SETUP_SECRETS_GUIDE.md for detailed setup instructions
# 4. For production, use AWS Secrets Manager instead of .env files
# ============================================================================
