# ============================================================================
# Web Portal Environment Configuration - EXAMPLE
# ============================================================================
# Copy this file to .env and fill in your actual values
# Command: cp .env.example .env
# ============================================================================

# ────────────────────────────────────────────────────────────────────────────
# API GATEWAY URL
# ────────────────────────────────────────────────────────────────────────────
# Point to your running API Gateway service
# Development: http://localhost:8000
# Production: https://api.yourdomain.com
VITE_API_URL=http://localhost:8000

# ============================================================================
# NOTES
# ============================================================================
# 1. This file should be copied to .env and gitignored
# 2. VITE_API_URL is the only required environment variable for the web portal
# 3. Change this to your production API URL when deploying
# ============================================================================
