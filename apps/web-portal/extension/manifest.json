{
  "manifest_version": 3,
  "name": "ZeroTrust AI — Verify Anything",
  "short_name": "ZeroTrust",
  "description": "Real-time fact verification, deepfake detection, and source credibility powered by a 6-agent AI system.",
  "version": "1.0.0",

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "ZeroTrust AI"
  },

  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],

  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },

  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "sidePanel",
    "scripting"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "commands": {
    "verify-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+V",
        "mac": "Command+Shift+V"
      },
      "description": "Verify selected text or current page URL"
    }
  },

  "web_accessible_resources": [
    {
      "resources": ["content/overlay.html", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
