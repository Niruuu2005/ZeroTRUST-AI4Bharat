# Copy this to .env.local and fill in values — NEVER commit .env.local
#
# IN-HOUSE FIRST: The app uses scraping and free sources by default:
#   - Web/search: DuckDuckGo (no key)
#   - News: RSS feeds (BBC, Reuters, AP, Guardian, Indian Express, etc.) + DuckDuckGo news (no key)
#   - Social: Reddit public search (no key)
#   - Scientific: PubMed E-utilities + arXiv (no key required; optional PUBMED_API_KEY for higher rate limits)
#   - Scraper: Direct fetch of URLs (no key)
# You only need AWS credentials for Bedrock (LLM). Third-party API keys below are optional.

# ── API Gateway (required to run the API) ─────────
# When running from repo root, API gateway loads this file from .env.local
DATABASE_URL=postgresql://user:password@localhost:5432/zerotrust
REDIS_URL=redis://localhost:6379
JWT_SECRET=<generate-a-long-random-secret-e.g.-openssl-rand-hex-32>

# ── AWS (required for real LLM verification) ───────
# Use real values only in .env.local (gitignored). Rotate keys if these were ever committed.
AWS_ACCESS_KEY_ID=<your-aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-access-key>
AWS_DEFAULT_REGION=us-east-1

# ── Media pipeline (API Gateway + media-analysis service) ─
# MEDIA_ENGINE_URL=http://localhost:8001

# ── Optional: S3 media upload (presigned URL endpoint) ─
# S3_MEDIA_BUCKET=

# ── Optional: CloudWatch Logs (when set, API gateway logs to this group) ─
# CW_LOG_GROUP=
# CW_LOG_STREAM_PREFIX=api-gateway

# ── Optional third-party APIs (leave empty to use in-house only) ─
# NEWS_API_KEY=
# GNEWS_API_KEY=
# GOOGLE_SEARCH_KEY=
# GOOGLE_SEARCH_ENGINE_ID=
# TWITTER_BEARER_TOKEN=
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# PUBMED_API_KEY=
# AFP_API_KEY=
